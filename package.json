{
  "name": "content-map",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/generate-images.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "playwright test --project=chromium",
    "test:smoke": "playwright test --grep @smoke --project=chromium",
    "test:regression": "playwright test tests/e2e/regression --project=chromium --workers=1",
    "test:api": "playwright test tests/e2e/api --project=chromium",
    "test:integration": "playwright test tests/e2e/integration --project=chromium",
    "test:a11y": "playwright test tests/e2e/a11y --project=chromium",
    "test:visual": "playwright test tests/e2e/visual --project=chromium --workers=1",
    "test:visual:update": "playwright test tests/e2e/visual --project=chromium --workers=1 --update-snapshots",
    "test:seo": "playwright test tests/e2e/seo --project=chromium --workers=1",
    "test:responsive": "playwright test tests/e2e/responsive --project=mobile-chrome --workers=1",
    "test:cross-browser": "playwright test tests/e2e/cross-browser --project=chromium --project=firefox --project=webkit --project=mobile-chrome --project=mobile-safari",
    "test:catalog": "playwright test tests/e2e/regression/catalog.spec.ts --project=chromium",
    "test:search": "playwright test tests/e2e/regression/search.spec.ts --project=chromium",
    "test:cart": "playwright test tests/e2e/regression/cart.spec.ts --project=chromium",
    "test:checkout": "playwright test tests/e2e/regression/checkout.spec.ts --project=chromium",
    "test:e2e": "playwright test tests/e2e --project=chromium",
    "test:headed": "playwright test --headed --project=chromium",
    "test:debug": "playwright test --debug --project=chromium",
    "test:report": "playwright show-report",
    "test:pr": "playwright test tests/e2e/smoke tests/e2e/api tests/e2e/integration tests/e2e/a11y tests/e2e/seo tests/e2e/responsive --project=chromium --workers=2",
    "test:ci": "npm run test:pr",
    "download:images": "node scripts/download-product-photos.mjs",
    "validate:images": "tsx scripts/validate-product-images.ts"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "bootstrap": "^5.3.8",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-bootstrap": "^2.10.10",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
